{
  "manifest_version": 2,
  "name": "DTU Lautschrift-Übersetzer",
  "version": "1.0",
  "description": "Ersetzt Phonetik-Blöcke von DDO zu Kiel,SchwaTilgung auf Webseiten.",
  "permissions": ["<all_urls>"],
  "web_accessible_resources": [
    "src/translationTable.csv"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["src/styles.css"],
      "js": ["dist/content-script.js"],
      "run_at": "document_end"
    }
  ]
}

