{
  "manifest_version": 2,
  "name": "Replace A with B",
  "version": "1.0",
  "description": "Ersetzt alle 'a' durch 'b' auf Webseiten.",
  "permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ]
}

